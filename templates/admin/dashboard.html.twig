{% block javascripts %}
{{ parent() }}
{% verbatim %}
<script>

window.openSubModal = function(id){
  const modal = document.getElementById(id);
  if(modal){ 
    modal.style.setProperty('display', 'flex', 'important');
  }
};
window.closeSubModal = function(id){
  const modal = document.getElementById(id);
  if(modal){ 
    modal.style.setProperty('display', 'none', 'important');
  }
};

document.querySelectorAll('.db-nav-item').forEach(function(item){
  item.addEventListener('click', function(e){
    e.preventDefault();
    const section = this.dataset.section;
    document.querySelectorAll('.db-nav-item').forEach(i => i.classList.remove('active'));
    document.querySelectorAll('.db-section').forEach(s => s.classList.remove('active'));
    this.classList.add('active');
    document.getElementById('section-' + section).classList.add('active');
  });
});
window.toggleAvatarMenu = function(){
  const menu = document.getElementById('avatar-menu');
  menu.classList.toggle('open');
};
document.addEventListener('click', function(e){
  if(!e.target.closest('.db-avatar-wrap')){
    const menu = document.getElementById('avatar-menu');
    if(menu) menu.classList.remove('open');
  }
});
window.closeFiche = function(id){
  const modal = document.getElementById('modal-fiche-' + id);
  if(modal){ modal.style.display = 'none'; document.body.style.overflow = ''; }
};

window.openFiche = function(id, statut){
  const modal = document.getElementById('modal-fiche-' + id);
  if(modal){
    modal.style.display = 'flex';
    document.body.style.overflow = 'hidden';
    const actionsEnAttente = modal.querySelector('.actions-en-attente');
    const actionsConfirme = modal.querySelector('.actions-confirme');
    if(statut === 'en_attente'){
      if(actionsEnAttente) actionsEnAttente.style.display = 'flex';
      if(actionsConfirme) actionsConfirme.style.display = 'none';
    } else {
      if(actionsEnAttente) actionsEnAttente.style.display = 'none';
      if(actionsConfirme) actionsConfirme.style.display = 'flex';
    }
  }
};

</script>
{% endverbatim %}
{% endblock %}

