<div class="modal-overlay" id="modal-fiche-ahmed" style="display:none;align-items:center;justify-content:center;">
  <div class="modal-box" style="max-width:620px;padding:0;overflow:hidden;">
    <button class="modal-close" onclick="closeFiche('ahmed')" style="position:absolute;top:14px;right:14px;z-index:10;">×</button>

