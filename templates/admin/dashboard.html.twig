    const row = button.closest('[data-student-row]');
    const studentName = button.dataset.studentName || 'cet élève';

    const ok = window.confirm('Retirer ' + studentName + ' de cette classe ?');

    if (!ok) {
        return;
    }

    row.remove();
});

