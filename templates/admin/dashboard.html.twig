        </div>
        <div style="background:var(--paper);border-radius:10px;padding:14px 16px;">
          <div style="font-size:11px;color:#888;margin-bottom:4px;">Date de naissance</div>
          <div style="font-size:14px;font-weight:600;color:var(--ink);">15/03/1990</div>
        </div>
        <div style="background:var(--paper);border-radius:10px;padding:14px 16px;">
          <div style="font-size:11px;color:#888;margin-bottom:4px;">Email</div>
          <div style="font-size:14px;font-weight:600;color:var(--ink);">ahmed@email.com</div>
