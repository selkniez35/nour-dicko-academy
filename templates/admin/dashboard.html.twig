{% extends 'base.html.twig' %}

{% block title %}Administration — Nour Dicko Academy{% endblock %}

{% block body %}
    <div class="dashboard">

        <aside class="db-sidebar db-sidebar-admin">

            <div class="db-brand">
                <img src="{{ asset('images/logo-nda.png') }}" alt="NDA">
                <span class="db-admin-badge">Admin</span>
            </div>

            <nav class="db-nav">

                <a href="#" class="db-nav-item active" data-section="overview">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <rect x="3" y="3" width="7" height="7"/>
                        <rect x="14" y="3" width="7" height="7"/>
                        <rect x="3" y="14" width="7" height="7"/>
                        <rect x="14" y="14" width="7" height="7"/>
                    </svg>
                    Tableau de bord
                </a>

                <a href="#" class="db-nav-item" data-section="students">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/>
                        <circle cx="9" cy="7" r="4"/>
                        <path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/>
                    </svg>
                    Élèves
                </a>

                <a href="#" class="db-nav-item" data-section="teachers">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M22 10v6M2 10l10-5 10 5-10 5z"/>
                        <path d="M6 12v5c3 3 9 3 12 0v-5"/>
                    </svg>
                    Enseignants
                </a>

                <a href="#" class="db-nav-item" data-section="trainings">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
                        <path d="M9 22V12h6v10"/>
                    </svg>
                    Classes
                </a>

                <a href="#" class="db-nav-item" data-section="registrations">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
                        <path d="M14 2v6h6"/>
                        <path d="M12 18v-6"/>
                        <path d="M9 15h6"/>
                    </svg>
                    Inscriptions
                </a>

                <a href="#" class="db-nav-item" data-section="payments">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <rect x="1" y="4" width="22" height="16" rx="2"/>
                        <path d="M1 10h22"/>
                    </svg>
                    Paiements
                </a>

                <a href="#" class="db-nav-item" data-section="news">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M4 22h16a2 2 0 002-2V4a2 2 0 00-2-2H8a2 2 0 00-2 2v16a2 2 0 01-2 2zm0 0a2 2 0 01-2-2v-9c0-1.1.9-2 2-2h2"/>
                        <path d="M18 14h-8"/>
                        <path d="M15 18h-5"/>
                        <path d="M10 6h8v4h-8z"/>
                    </svg>
                    Actualités
                </a>

            </nav>

            <a href="{{ path('app_logout') }}" class="db-logout">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/>
                    <path d="M16 17l5-5-5-5"/>
                    <path d="M21 12H9"/>
                </svg>

                Déconnexion
            </a>

        </aside>

        <main class="db-main">

            <div class="db-header">

                <div>
                    <h1 class="db-welcome">
                        Administration
                        <span>Nour Dicko Academy</span>
                    </h1>

                    <p class="db-sub">
                        Gestion de l'école
                    </p>
                </div>

                <div class="db-avatar-wrap">

                    <div class="db-avatar db-avatar-admin"
                         onclick="toggleAvatarMenu()">

                        {{ app.user.profile.fullName|first|upper }}

                    </div>

                    <div class="db-avatar-menu" id="avatar-menu">

                        <a href="{{ path('app_logout') }}"
                           class="db-avatar-logout">

                            Déconnexion

                        </a>

                    </div>

                </div>

            </div>

            {% include 'admin/partials/overview.html.twig' %}

            {% include 'admin/partials/_students.html.twig' %}

            {% include 'admin/partials/_teachers.html.twig' %}

            {% include 'admin/partials/_trainings.html.twig' %}

            {% include 'admin/partials/_registrations.html.twig' %}

            {% include 'admin/partials/_payments.html.twig' %}

            {% include 'admin/partials/_news.html.twig' %}

        </main>

    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}

    <script>

        document.querySelectorAll('.db-nav-item').forEach(item => {

            item.addEventListener('click', e => {

                e.preventDefault();

                document.querySelectorAll('.db-nav-item')
                    .forEach(i => i.classList.remove('active'));

                document.querySelectorAll('.db-section')
                    .forEach(s => s.classList.remove('active'));

                item.classList.add('active');

                document
                    .getElementById('section-' + item.dataset.section)
                    .classList.add('active');

            });

        });

        function toggleAvatarMenu() {
            document
                .getElementById('avatar-menu')
                .classList.toggle('open');
        }

        document.addEventListener('click', function (e) {

            if (!e.target.closest('.db-avatar-wrap')) {

                document
                    .getElementById('avatar-menu')
                    .classList.remove('open');

            }

        });

    </script>

{% endblock %}
