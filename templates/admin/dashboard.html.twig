{% extends 'base.html.twig' %}

{% block title %}Administration — Nour Dicko Academy{% endblock %}

{% block body %}
    <div class="dashboard">

    <div class="welcome-toast" id="welcome-toast">
        <div class="welcome-toast-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><path d="M9 22V12h6v10"/></svg>
        </div>
        <div class="welcome-toast-body">
            <div class="welcome-toast-title">Bienvenue {{ app.user.fullName }} 👋</div>
            <div class="welcome-toast-sub">Vous êtes connecté à l'espace admin NDA</div>
        </div>
    </div>

    <!-- ══ SIDEBAR ══ -->
    <aside class="db-sidebar db-sidebar-admin">
        <div class="db-brand">
            <img src="{{ asset('images/logo-nda.png') }}" alt="NDA">
            <span class="db-admin-badge">Admin</span>
        </div>
        <nav class="db-nav">
            <a href="#" class="db-nav-item active" data-section="overview">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
                Tableau de bord
            </a>
            <a href="#" class="db-nav-item" data-section="utilisateurs">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="4"/><path d="M20 21a8 8 0 00-16 0"/></svg>
                Utilisateurs
            </a>
            <a href="#" class="db-nav-item" data-section="eleves">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
                Élèves
            </a>
            <a href="#" class="db-nav-item" data-section="enseignants">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>
                Enseignants
            </a>
            <a href="#" class="db-nav-item" data-section="classes">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><path d="M9 22V12h6v10"/></svg>
                Classes
            </a>
            <a href="#" class="db-nav-item" data-section="inscriptions">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><path d="M14 2v6h6M12 18v-6M9 15h6"/></svg>
                Inscriptions
            </a>
            <a href="#" class="db-nav-item" data-section="paiements">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="4" width="22" height="16" rx="2"/><path d="M1 10h22"/></svg>
                Paiements
            </a>
            <a href="#" class="db-nav-item" data-section="calendrier">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="17" rx="2"/><path d="M3 9h18M8 2v4M16 2v4"/></svg>
                Calendrier
            </a>
            <a href="#" class="db-nav-item" data-section="actualites">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 22h16a2 2 0 002-2V4a2 2 0 00-2-2H8a2 2 0 00-2 2v16a2 2 0 01-2 2zm0 0a2 2 0 01-2-2v-9c0-1.1.9-2 2-2h2"/><path d="M18 14h-8M15 18h-5M10 6h8v4h-8z"/></svg>
                Actualités
            </a>
        </nav>
        <a href="{{ path('app_logout') }}" class="db-logout">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4M16 17l5-5-5-5M21 12H9"/></svg>
            Déconnexion
        </a>
    </aside>

    <!-- ══ CONTENU PRINCIPAL ══ -->
    <main class="db-main">

    <!-- Header -->
    <div class="db-header">
        <div>
            <h1 class="db-welcome">Administration <span>NDA</span></h1>
            <p class="db-sub">Gestion complète de Nour Dicko Academy</p>
        </div>
        <div class="db-avatar-wrap">
            <div class="db-avatar db-avatar-admin" onclick="toggleAvatarMenu()">A</div>
            <div class="db-avatar-menu" id="avatar-menu">
                <a href="{{ path('app_logout') }}" class="db-avatar-logout">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4M16 17l5-5-5-5M21 12H9"/></svg>
                    Déconnexion
                </a>
            </div>
        </div>
    </div>

    <!-- ══ SECTION : Vue d'ensemble ══ -->
    <section class="db-section active" id="section-overview">
        <h2 class="db-section-title">Vue d'ensemble</h2>

        <div class="admin-stats">
            <div class="admin-stat-card">
                <div class="admin-stat-icon" style="background:rgba(201,146,42,.12);color:var(--gold)">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
                </div>
                <div>
                    <div class="admin-stat-val">{{ stats.students|default(0) }}</div>
                    <div class="admin-stat-label">Élèves inscrits</div>
                </div>
            </div>
            <div class="admin-stat-card">
                <div class="admin-stat-icon" style="background:rgba(26,42,74,.1);color:#1a2a4a">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/></svg>
                </div>
                <div>
                    <div class="admin-stat-val">{{ stats.teachers|default(0) }}</div>
                    <div class="admin-stat-label">Enseignants</div>
                </div>
            </div>
            <div class="admin-stat-card">
                <div class="admin-stat-icon" style="background:rgba(34,197,94,.1);color:#16a34a">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="4" width="22" height="16" rx="2"/><path d="M1 10h22"/></svg>
                </div>
                <div>
                    <div class="admin-stat-val">{{ (stats.revenue|default(0) / 100)|number_format(2, ',', ' ') }} €</div>
                    <div class="admin-stat-label">Revenus annuels</div>
                </div>
            </div>
            <div class="admin-stat-card">
                <div class="admin-stat-icon" style="background:rgba(239,68,68,.1);color:#dc2626">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/></svg>
                </div>
                <div>
                    <div class="admin-stat-val">{{ stats.registrations|default(0) }}</div>
                    <div class="admin-stat-label">Nouvelles inscriptions <span style="opacity:.6">(7 derniers jours)</span></div>
                </div>
            </div>
        </div>

        <h3 class="db-subsection-title">Dernières inscriptions</h3>
        <div class="admin-table">
            <div class="admin-table-header">
                <span>Nom</span><span>Cours</span><span>Date</span><span>Statut</span><span>Action</span>
            </div>
            {% for registration in latestRegistrations %}
                <div class="admin-table-row">
            <span class="db-eleve-name">
              <div class="db-eleve-avatar">{{ (registration.userProfile ? registration.userProfile.fullName : '-')|first|upper }}</div>
              {{ registration.userProfile ? registration.userProfile.fullName : '-' }}
            </span>
                    <span>{{ registration.plan ? registration.plan.label : (registration.studentLevel ?: '-') }}</span>
                    <span>{{ registration.createdAt|date('d/m/Y') }}</span>
                    <span class="db-eleve-badge {% if registration.status.value == 'active' %}db-badge-actif{% elseif registration.status.value == 'pending' %}db-badge-pending{% else %}db-badge-refuse{% endif %}">
              {{ registration.status.label }}
            </span>
                    <span>
              <a href="{{ path('app_admin_membership_edit', {id: registration.id}) }}" class="admin-btn-sm">Voir</a>
            </span>
                </div>
            {% else %}
                <div class="admin-table-row"><span colspan="5">Aucune inscription récente.</span></div>
            {% endfor %}
        </div>
    </section>

    <!-- ══ SECTION : Utilisateurs ══ -->
    <section class="db-section" id="section-utilisateurs">
        <div class="admin-section-head">
            <h2 class="db-section-title">Utilisateurs</h2>
        </div>
        <div class="admin-table">
            <div class="admin-table-header" style="grid-template-columns:2fr 2fr 1.3fr 2fr 1.4fr;">
                <span>Nom</span><span>Email</span><span>Rôle actuel</span><span>Changer le rôle</span><span>Actions</span>
            </div>
            {% for oneUser in allUsers %}
                <div class="admin-table-row" style="grid-template-columns:2fr 2fr 1.3fr 2fr 1.4fr;">
                    <span class="db-eleve-name">
                        <div class="db-eleve-avatar">{{ (oneUser.profile ? oneUser.profile.fullName : oneUser.email)|first|upper }}</div>
                        {{ oneUser.profile ? oneUser.profile.fullName : oneUser.email }}
                    </span>
                    <span>{{ oneUser.email }}</span>
                    <span>
                        {% if 'ROLE_ADMIN' in oneUser.roles %}
                            {% set primaryRole = 'ROLE_ADMIN' %}
                        {% elseif 'ROLE_TEACHER' in oneUser.roles %}
                            {% set primaryRole = 'ROLE_TEACHER' %}
                        {% else %}
                            {% set primaryRole = 'ROLE_USER' %}
                        {% endif %}
                        {% if primaryRole == 'ROLE_ADMIN' %}
                            <span class="db-eleve-badge db-badge-actif">Admin</span>
                        {% elseif primaryRole == 'ROLE_TEACHER' %}
                            <span class="db-eleve-badge db-badge-pending">Enseignant</span>
                        {% else %}
                            <span class="db-eleve-badge" style="background:rgba(26,42,74,.08);color:#1a2a4a;font-size:11.5px;font-weight:700;padding:3px 10px;border-radius:999px;display:inline-block;">Utilisateur</span>
                        {% endif %}
                    </span>
                    <span>
                        {% if oneUser == app.user %}
                            <span style="font-size:12px;opacity:.5;">— vous-même —</span>
                        {% else %}
                            <form method="post" action="{{ path('app_admin_user_role_update', {id: oneUser.id}) }}" style="display:flex;gap:6px;">
                                <input type="hidden" name="_token" value="{{ csrf_token('change-role-' ~ oneUser.id) }}">
                                <select name="role" style="font-family:var(--font-body);font-size:13px;background:var(--paper);border:1.5px solid var(--gold-pale);border-radius:8px;padding:6px 10px;">
                                    {% for label, value in availableRoles %}
                                        <option value="{{ value }}" {% if value == primaryRole %}selected{% endif %}>{{ label }}</option>
                                    {% endfor %}
                                </select>
                                <button type="submit" class="admin-btn-sm">Changer</button>
                            </form>
                        {% endif %}
                    </span>
                    <span class="admin-actions">
                        <a href="{{ path('app_admin_user_edit', {id: oneUser.id}) }}" class="admin-btn-sm">Modifier</a>
                        <form method="post" action="{{ path('app_admin_user_delete', {id: oneUser.id}) }}" style="display:inline" onsubmit="return confirm('Supprimer cet utilisateur ?');">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete-user-' ~ oneUser.id) }}">
                            <button class="admin-btn-sm admin-btn-danger" type="submit">Supprimer</button>
                        </form>
                    </span>
                </div>
            {% else %}
                <div class="admin-table-row"><span>Aucun utilisateur trouvé.</span></div>
            {% endfor %}
        </div>
    </section>

    <!-- ══ SECTION : Élèves ══ -->
    <section class="db-section" id="section-eleves">
        <div class="admin-section-head">
            <h2 class="db-section-title">Élèves</h2>
        </div>
        <div class="admin-search">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
            <label>
                <input type="text" placeholder="Rechercher un élève...">
            </label>
        </div>
        <div class="admin-table">
            <div class="admin-table-header">
                <span>Nom</span><span>Email</span><span>Cours</span><span>Paiement</span><span>Statut</span><span>Actions</span>
            </div>
            {% for student in students %}
                {% set profile = student.profile %}
                {% set membership = profile and profile.memberships|length > 0 ? profile.memberships|last : null %}
                <div class="admin-table-row">
            <span class="db-eleve-name">
              <div class="db-eleve-avatar">{{ (profile ? profile.fullName : student.email)|first|upper }}</div>

              {{ profile ? profile.fullName : student.email }}
            </span>
                    <span>{{ student.email }}</span>
                    <span>{{ membership and membership.plan ? membership.plan.label : '-' }}</span>
                    <span>
              {% if membership and membership.payments|length > 0 %}
                  <span class="db-badge-actif">À jour</span>
              {% else %}
                  <span class="db-badge-pending">En attente</span>
              {% endif %}
            </span>
                    <span class="db-eleve-badge {% if membership and membership.status.value == 'active' %}db-badge-actif{% else %}db-badge-pending{% endif %}">
              {{ membership ? membership.status.label : 'Aucune inscription' }}
            </span>
                    <span class="admin-actions">
              <a href="{{ path('app_admin_user_edit', {id: student.id}) }}" class="admin-btn-sm">Modifier</a>
              <form method="post" action="{{ path('app_admin_user_delete', {id: student.id}) }}" style="display:inline" onsubmit="return confirm('Supprimer cet élève ?');">
                  <input type="hidden" name="_token" value="{{ csrf_token('delete-user-' ~ student.id) }}">
                  <button class="admin-btn-sm admin-btn-danger" type="submit">Supprimer</button>
              </form>
            </span>
                </div>
            {% else %}
                <div class="admin-table-row"><span>Aucun élève trouvé.</span></div>
            {% endfor %}
        </div>
    </section>

    <!-- ══ SECTION : Enseignants ══ -->
    <section class="db-section" id="section-enseignants">
        <div class="admin-section-head">
            <h2 class="db-section-title">Enseignants</h2>
            <a href="{{ path('app_admin_teacher_new') }}" class="admin-btn-primary">+ Ajouter un enseignant</a>
        </div>
        <div class="admin-table">
            <div class="admin-table-header">
                <span>Nom</span><span>Email</span><span>Téléphone</span><span>Statut</span><span>Actions</span>
            </div>
            {% for teacher in teachers %}
                {% set profile = teacher.profile %}
                <div class="admin-table-row">
            <span class="db-eleve-name">
              <div class="db-eleve-avatar">{{ (profile ? profile.fullName : teacher.email)|first|upper }}</div>
              {{ profile ? profile.fullName : teacher.email }}
            </span>
                    <span>{{ teacher.email }}</span>
                    <span>{{ profile and profile.phoneNumber ? profile.phoneNumber : '-' }}</span>
                    <span class="db-eleve-badge db-badge-actif">Actif</span>
                    <span class="admin-actions">
              <a href="{{ path('app_admin_user_edit', {id: teacher.id}) }}" class="admin-btn-sm">Modifier</a>
              <form method="post" action="{{ path('app_admin_user_delete', {id: teacher.id}) }}" style="display:inline" onsubmit="return confirm('Supprimer cet enseignant ?');">
                  <input type="hidden" name="_token" value="{{ csrf_token('delete-user-' ~ teacher.id) }}">
                  <button class="admin-btn-sm admin-btn-danger" type="submit">Supprimer</button>
              </form>
            </span>
                </div>
            {% else %}
                <div class="admin-table-row"><span>Aucun enseignant enregistré.</span></div>
            {% endfor %}
        </div>
    </section>

    <!-- ══ SECTION : Classes ══ -->
    <section class="db-section" id="section-classes">
        <div class="admin-section-head">
            <h2 class="db-section-title">Classes</h2>
            <a href="{{ path('app_admin_plan_new') }}" class="admin-btn-primary">+ Créer une classe</a>
        </div>
        <div class="db-cours-grid">
            {% for plan in plans %}
                <div class="db-cours-card">
                    <div class="db-cours-icon">
                        {% if plan.label matches '/arabe/i' %}
                            <span class="glyph" lang="ar">ض</span>
                        {% else %}
                            <svg viewBox="0 0 24 24" fill="none" stroke="#0C0C0C" stroke-width="1.8"><path d="M12 2c0 3-3.5 4-3.5 7a3.5 3.5 0 007 0C15.5 6 12 5 12 2z"/><path d="M4 21v-7h16v7M4 21h16M9 21v-4a3 3 0 016 0v4"/></svg>
                        {% endif %}
                    </div>
                    <div class="db-cours-info">
                        <h3>{{ plan.label }}</h3>
                        <span class="db-cours-badge">Niveau : {{ plan.level }}</span>
                        <span class="db-cours-badge">🗓 {{ plan.schedule }}</span>
                        <span class="db-cours-badge">💰 {{ plan.price|number_format(2, ',', ' ') }} €</span>
                    </div>
                    <div class="admin-actions">
                        <a href="{{ path('app_admin_plan_edit', {id: plan.id}) }}" class="admin-btn-sm">Gérer</a>
                        <form method="post" action="{{ path('app_admin_plan_delete', {id: plan.id}) }}" style="display:inline" onsubmit="return confirm('Supprimer cette classe ?');">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete-plan-' ~ plan.id) }}">
                            <button class="admin-btn-sm admin-btn-danger" type="submit">Supprimer</button>
                        </form>
                    </div>
                </div>
            {% else %}
                <div class="db-cours-card"><div class="db-cours-info"><h3>Aucune classe disponible</h3></div></div>
            {% endfor %}
        </div>
    </section>

    <!-- ══ SECTION : Inscriptions ══ -->
    <section class="db-section" id="section-inscriptions">
        <div class="admin-section-head">
            <h2 class="db-section-title">Inscriptions</h2>
            <span class="db-eleve-badge db-badge-pending">{{ stats.registrations|default(0) }} nouvelle(s) sur 7 jours</span>
        </div>
        <div class="admin-table">
            <div class="admin-table-header">
                <span>Nom</span><span>Cours souhaité</span><span>Date</span><span>Statut</span><span>Actions</span>
            </div>
            {% for membership in allMemberships %}
                <div class="admin-table-row">
            <span class="db-eleve-name">
              <div class="db-eleve-avatar">{{ (membership.userProfile ? membership.userProfile.fullName : '-')|first|upper }}</div>
              {{ membership.userProfile ? membership.userProfile.fullName : '-' }}
            </span>
                    <span>{{ membership.plan ? membership.plan.label : (membership.studentLevel ?: '-') }}</span>
                    <span>{{ membership.createdAt|date('d/m/Y') }}</span>
                    <span class="db-eleve-badge {% if membership.status.value == 'active' %}db-badge-actif{% elseif membership.status.value == 'pending' %}db-badge-pending{% else %}db-badge-refuse{% endif %}">
              {{ membership.status.label }}
            </span>
                    <span class="admin-actions">
              <a href="{{ path('app_admin_membership_edit', {id: membership.id}) }}" class="admin-btn-sm">Modifier</a>
              <form method="post" action="{{ path('app_admin_membership_delete', {id: membership.id}) }}" style="display:inline" onsubmit="return confirm('Supprimer cette inscription ?');">
                  <input type="hidden" name="_token" value="{{ csrf_token('delete-membership-' ~ membership.id) }}">
                  <button class="admin-btn-sm admin-btn-danger" type="submit">Supprimer</button>
              </form>
            </span>
                </div>
            {% else %}
                <div class="admin-table-row"><span colspan="5">Aucune inscription.</span></div>
            {% endfor %}
        </div>
    </section>

    <!-- ══ SECTION : Paiements ══ -->
    <section class="db-section" id="section-paiements">
        <h2 class="db-section-title">Paiements</h2>
        <div class="admin-stats" style="margin-bottom:28px">
            <div class="admin-stat-card">
                <div class="admin-stat-icon" style="background:rgba(34,197,94,.1);color:#16a34a">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
                </div>
                <div>
                    <div class="admin-stat-val">{{ (paymentStats.received|default(0) / 100)|number_format(2, ',', ' ') }} €</div>
                    <div class="admin-stat-label">Reçus</div>
                </div>
            </div>
            <div class="admin-stat-card">
                <div class="admin-stat-icon" style="background:rgba(239,68,68,.1);color:#dc2626">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4M12 16h.01"/></svg>
                </div>
                <div>
                    <div class="admin-stat-val">{{ (paymentStats.pending|default(0) / 100)|number_format(2, ',', ' ') }} €</div>
                    <div class="admin-stat-label">En attente</div>
                </div>
            </div>
        </div>
        <div class="admin-table">
            <div class="admin-table-header">
                <span>Élève</span><span>Montant</span><span>Date</span><span>Mode</span><span>Statut</span>
            </div>
            {% for payment in latestPayments %}
                <div class="admin-table-row">
            <span class="db-eleve-name">
              <div class="db-eleve-avatar">{{ (payment.user and payment.user.profile ? payment.user.profile.fullName : payment.internalRef)|first|upper }}</div>
              {{ payment.user and payment.user.profile ? payment.user.profile.fullName : payment.internalRef }}
            </span>
                    <span>{{ (payment.amount / 100)|number_format(2, ',', ' ') }} €</span>
                    <span>{{ payment.createdAt|date('d/m/Y') }}</span>
                    <span>{{ payment.method ? payment.method.value : '-' }}</span>
                    <span class="db-eleve-badge {% if payment.status.value == 'paid' %}db-badge-actif{% elseif payment.status.value == 'pending' %}db-badge-pending{% else %}db-badge-danger{% endif %}">
              {% if payment.status.value == 'paid' %}Payé{% elseif payment.status.value == 'pending' %}En attente{% else %}{{ payment.status.value|capitalize }}{% endif %}
            </span>
                </div>
            {% else %}
                <div class="admin-table-row"><span>Aucun paiement trouvé.</span></div>
            {% endfor %}
        </div>
    </section>

    <!-- ══ SECTION : Calendrier ══ -->
    <section class="db-section" id="section-calendrier">
        <div class="admin-section-head">
            <h2 class="db-section-title">Calendrier des cours</h2>
            <a href="{{ path('app_admin_session_new') }}" class="admin-btn-primary">+ Ajouter une séance</a>
        </div>

        <script type="application/json" id="admin-sessions-data">{{ courseSessionsData|default([])|json_encode|raw }}</script>

        <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-bottom:28px;">
            <div class="db-stat-mini">
                <div class="db-stat-mini-val">{{ calendarStats.totalSessions|default(0) }}</div>
                <div class="db-stat-mini-label">Séances totales</div>
            </div>
            {% for plan in plans|slice(0,3) %}
                <div class="db-stat-mini">
                    <div class="db-stat-mini-val" style="font-size:18px;">{{ plan.schedule|default('-') }}</div>
                    <div class="db-stat-mini-label">{{ plan.label }}</div>
                </div>
            {% endfor %}
        </div>
        <div style="display:flex;align-items:center;justify-content:center;gap:20px;margin-bottom:24px;">
            <button onclick="prevMonthAdmin()" style="background:var(--black);color:var(--gold);border:none;cursor:pointer;width:38px;height:38px;border-radius:50%;font-size:18px;display:flex;align-items:center;justify-content:center;">‹</button>
            <div id="nav-title-admin" style="font-family:var(--font-display),sans-serif;font-size:24px;font-weight:700;min-width:220px;text-align:center;"></div>
            <button onclick="nextMonthAdmin()" style="background:var(--black);color:var(--gold);border:none;cursor:pointer;width:38px;height:38px;border-radius:50%;font-size:18px;display:flex;align-items:center;justify-content:center;">›</button>
        </div>
        <div style="background:var(--white);border-radius:18px;border:1px solid var(--gold-pale);overflow:hidden;box-shadow:var(--shadow);">
            <div style="display:grid;grid-template-columns:repeat(7,1fr);background:var(--black);">
                <div class="nda-cal-dayname">Lun</div><div class="nda-cal-dayname">Mar</div><div class="nda-cal-dayname">Mer</div>
                <div class="nda-cal-dayname">Jeu</div><div class="nda-cal-dayname">Ven</div><div class="nda-cal-dayname">Sam</div><div class="nda-cal-dayname">Dim</div>
            </div>
            <div id="cal-days-admin" style="display:grid;grid-template-columns:repeat(7,1fr);"></div>
        </div>

        <h3 class="db-section-title" style="font-size:18px;margin:32px 0 16px;">Liste des séances</h3>
        <div class="admin-table">
            {% for session in courseSessions %}
                <div class="admin-table-row" style="grid-template-columns:1.4fr 2fr 1.6fr 1.2fr 1.4fr;">
                    <span>{{ session.startsAt|date('d/m/Y H:i') }}{% if session.endsAt %} – {{ session.endsAt|date('H:i') }}{% endif %}</span>
                    <span>{{ session.plan ? session.plan.label : '-' }}</span>
                    <span>{{ session.teacher ? session.teacher.firstName ~ ' ' ~ session.teacher.lastName : '—' }}</span>
                    <span class="admin-actions">
                        <a href="{{ path('app_admin_session_edit', {id: session.id}) }}" class="admin-btn-sm">Modifier</a>
                        <form method="post" action="{{ path('app_admin_session_delete', {id: session.id}) }}" style="display:inline" onsubmit="return confirm('Supprimer cette séance ?');">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete-session-' ~ session.id) }}">
                            <button class="admin-btn-sm admin-btn-danger" type="submit">Supprimer</button>
                        </form>
                    </span>
                </div>
            {% else %}
                <div class="admin-table-row"><span style="grid-column:1/-1;text-align:center">Aucune séance programmée. Cliquez sur « Ajouter une séance ».</span></div>
            {% endfor %}
        </div>
    </section>

    <!-- ══ SECTION : Actualités ══ -->
    <section class="db-section" id="section-actualites">
        <div class="admin-section-head">
            <h2 class="db-section-title">Actualités</h2>
            <a href="{{ path('app_admin_announcement_new') }}" class="admin-btn-primary">+ Nouvelle actualité</a>
        </div>
        <div class="db-resources">
            {% for news in latestNews %}
                <div class="db-resource-item">
                    <div class="db-resource-icon">
                        {% if news.type is defined and news.type == 'event' %}
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/></svg>
                        {% else %}
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 22h16a2 2 0 002-2V4a2 2 0 00-2-2H8a2 2 0 00-2 2v16a2 2 0 01-2 2zm0 0a2 2 0 01-2-2v-9c0-1.1.9-2 2-2h2"/></svg>
                        {% endif %}
                    </div>
                    <div class="db-resource-info">
                        <span class="db-resource-name">{{ news.title }}</span>
                        <span class="db-resource-date">Publié le {{ news.createdAt|date('d/m/Y') }}</span>
                    </div>
                    <div class="admin-actions">
                        <a href="{{ path('app_admin_announcement_edit', {id: news.id}) }}" class="admin-btn-sm">Modifier</a>
                        <form method="post" action="{{ path('app_admin_announcement_delete', {id: news.id}) }}" style="display:inline" onsubmit="return confirm('Supprimer cette actualité ?');">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete-announcement-' ~ news.id) }}">
                            <button class="admin-btn-sm admin-btn-danger" type="submit">Supprimer</button>
                        </form>
                    </div>
                </div>
            {% else %}
                <div class="db-resource-item"><div class="db-resource-info"><span class="db-resource-name">Aucune actualité publiée.</span></div></div>
            {% endfor %}
        </div>
    </section>

    </main>{# fin .db-main #}

    </div>{# fin .dashboard #}
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('dashboard-admin') }}
{% endblock %}
