{% extends 'base.html.twig' %}

{% block title %}{{ title }} — Nour Dicko Academy{% endblock %}

{% block body %}
<main class="admin-form-page">
    <div class="admin-form-card">
        <a href="{{ path(back_route) }}" class="admin-back-link">← Retour</a>

        <h1>{{ title }}</h1>

        {{ form_start(form) }}
            {{ form_widget(form) }}
            <button type="submit" class="admin-btn-primary">{{ submit_label|default('Enregistrer') }}</button>
        {{ form_end(form) }}
    </div>
</main>
{% endblock %}
