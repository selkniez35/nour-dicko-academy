<section class="db-section" id="section-news">

    <div class="admin-section-head">
        <h2 class="db-section-title">Actualités</h2>

        <a href="{{ path('app_admin_announcement_new') }}" class="admin-btn-primary">
            + Publier une actualité
        </a>
    </div>

    <div class="admin-table">
        <div class="admin-table-header">
            <span>Titre</span>
            <span>Cible</span>
            <span>Statut</span>
            <span>Date</span>
            <span>Actions</span>
        </div>

        {% for announcement in announcements %}
            <div class="admin-table-row">
                <span>{{ announcement.title }}</span>
                <span>{{ announcement.audience }}</span>
                <span>
                    {% if announcement.isPublished %}
                        <span class="db-eleve-badge db-badge-actif">Publiée</span>
                    {% else %}
                        <span class="db-eleve-badge db-badge-pending">Brouillon</span>
                    {% endif %}
                </span>
                <span>{{ announcement.createdAt|date('d/m/Y') }}</span>
                <span class="admin-actions">
                    <a href="{{ path('app_admin_announcement_edit', {id: announcement.id}) }}" class="admin-btn-sm">Voir</a>
                    <a href="{{ path('app_admin_announcement_edit', {id: announcement.id}) }}" class="admin-btn-sm">Modifier</a>

                    <form method="post"
                          action="{{ path('app_admin_announcement_delete', {id: announcement.id}) }}"
                          style="display:inline"
                          onsubmit="return confirm('Supprimer cette actualité ?');">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete-announcement-' ~ announcement.id) }}">
                        <button class="admin-btn-sm admin-btn-danger" type="submit">Supprimer</button>
                    </form>
                </span>
            </div>
        {% else %}
            <div class="admin-table-row">
                <span style="grid-column:1/-1;text-align:center">Aucune actualité trouvée.</span>
            </div>
        {% endfor %}
    </div>

</section>
