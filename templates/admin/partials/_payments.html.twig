<section class="db-section" id="section-payments">

    <div class="admin-section-head">
        <h2 class="db-section-title">Paiements</h2>
    </div>

    <div class="admin-table">
        <div class="admin-table-header">
            <span>Nom</span>
            <span>Montant</span>
            <span>Statut</span>
            <span>Date</span>
            <span>Actions</span>
        </div>

        {% for payment in payments %}
            <div class="admin-table-row">
                <span class="db-eleve-name">
                    <div class="db-eleve-avatar">
                        {{ (payment.user and payment.user.profile ? payment.user.profile.fullName : payment.internalRef)|first|upper }}
                    </div>
                    {{ payment.user and payment.user.profile ? payment.user.profile.fullName : payment.internalRef }}
                </span>

                <span>{{ payment.amount|number_format(2, ',', ' ') }} {{ payment.currency.value }}</span>

                <span>
                    {% if payment.status.value == 'paid' %}
                        <span class="db-eleve-badge db-badge-actif">Payé</span>
                    {% elseif payment.status.value == 'pending' %}
                        <span class="db-eleve-badge db-badge-pending">En attente</span>
                    {% else %}
                        <span class="db-eleve-badge db-badge-pending">{{ payment.status.value|capitalize }}</span>
                    {% endif %}
                </span>

                <span>{{ payment.createdAt|date('d/m/Y') }}</span>

                <span class="admin-actions">
                    <a href="{{ path('app_admin_payment_show', {id: payment.id}) }}" class="admin-btn-sm">Voir</a>
                </span>
            </div>
        {% else %}
            <div class="admin-table-row">
                <span style="grid-column:1/-1;text-align:center">Aucun paiement trouvé.</span>
            </div>
        {% endfor %}
    </div>

</section>
