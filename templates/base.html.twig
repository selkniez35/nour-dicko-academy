<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">

    <title>{% block title %}Club de Boxe à Guingamp{% endblock %}</title>

    <meta name="viewport" content="width=device-width, initial-scale=1">

    <link rel="icon" href="{{ asset('images/logos/favicon.ico') }}">

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

    {{ encore_entry_link_tags('app') }}
</head>

<body class="d-flex flex-column min-vh-100 app-body">

{# NAVBAR #}
{% include 'partials/navbar.html.twig' %}

{# FLASH MESSAGES #}
<div class="position-fixed top-0 start-50 translate-middle-x w-100" style="z-index:9999;">
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label }} text-center m-0 rounded-0 shadow-sm">
                {{ message }}
            </div>
        {% endfor %}
    {% endfor %}
</div>

{# CONTENU PRINCIPAL #}
<main class="flex-grow-1">
    {% block body %}{% endblock %}
</main>

{# FOOTER #}
{% include 'partials/footer.html.twig' %}

{{ encore_entry_script_tags('app') }}

</body>
</html>