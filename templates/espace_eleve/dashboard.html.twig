{% extends 'base.html.twig' %}
{% block title %}Mon espace — Nour Dicko Academy{% endblock %}

{% block body %}
<div class="dashboard">

    <div class="welcome-toast" id="welcome-toast">
  <div class="welcome-toast-icon">
    <svg viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2"><path d="M12 20V7M12 7c0-2.8 2-4.5 7-4.5v13c-5 0-7 1.2-7 4.5zm0 0c0-2.8-2-4.5-7-4.5v13c5 0 7 1.2 7 4.5z"/></svg>
  </div>
  <div class="welcome-toast-body">
    <div class="welcome-toast-title">Bienvenue, {{ app.user.fullName }} 👋</div>
    <div class="welcome-toast-sub">Vous êtes connecté à votre espace élève</div>
  </div>
</div>
    <!-- Sidebar -->
        <aside class="db-sidebar">
            <div class="db-brand">
              <img src="{{ asset('images/logo-nda.png') }}" alt="NDA">
            </div>
            <nav class="db-nav">
                <a href="#" class="db-nav-item active" data-section="cours">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20V7M12 7c0-2.8 2-4.5 7-4.5v13c-5 0-7 1.2-7 4.5zm0 0c0-2.8-2-4.5-7-4.5v13c5 0 7 1.2 7 4.5z"/></svg>
                Mes cours
              </a>
              <a href="#" class="db-nav-item" data-section="calendrier">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="17" rx="2"/><path d="M3 9h18M8 2v4M16 2v4"/></svg>
                Séances
              </a>
              <a href="#" class="db-nav-item" data-section="notes">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>
                    Mes évaluations
              </a>
              <a href="#" class="db-nav-item" data-section="profil">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
                Mon profil
              </a>
            </nav>
        </aside>

  <!-- Contenu principal -->
  <main class="db-main">

    <!-- Header -->
    <div class="db-header">
      <div>
        <h1 class="db-welcome">Bienvenue, <span>{{ app.user.fullName }}</span> 👋</h1>
        <p class="db-sub">Voici votre espace personnel Nour Dicko Academy</p>
      </div>
    </div>

    <!-- Section : Mes cours -->
    <section class="db-section active" id="section-cours">
      <h2 class="db-section-title">Mes cours</h2>

      <div class="db-cours-grid">
        {% for course in membership ? membership.selectedCourses : [] %}
          <div class="db-cours-card">
            <div class="db-cours-icon">
              <span class="glyph" lang="ar">ض</span>
            </div>
            <div class="db-cours-info">
              <h3>{{ course.label }}</h3>
              <span class="db-cours-badge">{{ course.schedule }}</span>
            </div>
            <a href="#" class="db-btn-zoom">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="13" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
              Rejoindre le cours
            </a>
          </div>
        {% else %}
          <p>Aucun cours pour le moment.</p>
        {% endfor %}
      </div>

      <!-- Ressources -->
      <h3 class="db-subsection-title">Ressources & Supports</h3>
      <div class="db-resources">
        <div class="db-resource-item">
          <div class="db-resource-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><path d="M14 2v6h6"/></svg>
          </div>
          <div class="db-resource-info">
            <span class="db-resource-name">Support — Séance 1</span>
            <span class="db-resource-date">Ajouté le 01/09/2025</span>
          </div>
          <a href="#" class="db-resource-dl">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M7 10l5 5 5-5M12 15V3"/></svg>
          </a>
        </div>
        {% for recording in recordings %}
          <div class="db-resource-item db-resource-video">
            <div class="db-resource-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2"/></svg>
            </div>
            <div class="db-resource-info">
              <span class="db-resource-name">{{ recording.title|default(recording.courseSession.plan ? 'Enregistrement — ' ~ recording.courseSession.plan.label : recording.originalFilename) }}</span>
              <span class="db-resource-date">{{ recording.courseSession.startsAt|date('d/m/Y') }}</span>
            </div>
            <a href="{{ path('app_recording_stream', {id: recording.id}) }}" target="_blank" rel="noopener" class="db-resource-dl">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8"/></svg>
            </a>
          </div>
        {% endfor %}
      </div>
    </section>

    <!-- Section : Calendrier -->
    <section class="db-section" id="section-calendrier">
  <h2 class="db-section-title">Mon calendrier de cours</h2>

  <!-- Stats -->
  <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:16px;margin-bottom:28px;">
    <div class="db-stat-mini">
      <div class="db-stat-mini-val">{{ sessions|length }}</div>
      <div class="db-stat-mini-label">Séances au total</div>
    </div>
    <div class="db-stat-mini">
      <div class="db-stat-mini-val">{{ sessions|filter(s => s.startsAt >= date())|length }}</div>
      <div class="db-stat-mini-label">Séances à venir</div>
    </div>
  </div>

  <script type="application/json" id="eleve-sessions-data">{{ sessionsData|default([])|json_encode|raw }}</script>

  <!-- Navigation -->
  <div style="display:flex;align-items:center;justify-content:center;gap:20px;margin-bottom:24px;">
    <button onclick="prevMonthEleve()" style="background:var(--black);color:var(--gold);border:none;cursor:pointer;width:38px;height:38px;border-radius:50%;font-size:18px;display:flex;align-items:center;justify-content:center;">‹</button>
    <div id="nav-title-eleve" style="font-family:var(--font-display);font-size:24px;font-weight:700;min-width:220px;text-align:center;"></div>
    <button onclick="nextMonthEleve()" style="background:var(--black);color:var(--gold);border:none;cursor:pointer;width:38px;height:38px;border-radius:50%;font-size:18px;display:flex;align-items:center;justify-content:center;">›</button>
  </div>

  <!-- Grille -->
  <div style="background:var(--white);border-radius:18px;border:1px solid var(--gold-pale);overflow:hidden;box-shadow:var(--shadow);">
    <div style="display:grid;grid-template-columns:repeat(7,1fr);background:var(--black);">
      <div class="nda-cal-dayname">Lun</div>
      <div class="nda-cal-dayname">Mar</div>
      <div class="nda-cal-dayname">Mer</div>
      <div class="nda-cal-dayname">Jeu</div>
      <div class="nda-cal-dayname">Ven</div>
      <div class="nda-cal-dayname">Sam</div>
      <div class="nda-cal-dayname">Dim</div>
    </div>
    <div id="cal-days-eleve" style="display:grid;grid-template-columns:repeat(7,1fr);"></div>
  </div>

  <!-- Légende -->
  <div style="display:flex;align-items:center;gap:24px;margin-top:18px;justify-content:center;flex-wrap:wrap;">
    <div style="display:flex;align-items:center;gap:8px;font-size:12px;opacity:.7;">
      <div style="width:12px;height:12px;border-radius:50%;background:rgba(201,146,42,.3);border:1px solid var(--gold);"></div>
      Mon cours
    </div>
    <div style="display:flex;align-items:center;gap:8px;font-size:12px;opacity:.7;">
      <div style="width:12px;height:12px;border-radius:50%;background:#f5f5f5;border:1px solid #ddd;"></div>
      Week-end
    </div>
    <div style="display:flex;align-items:center;gap:8px;font-size:12px;opacity:.7;">
      <div style="width:12px;height:12px;border-radius:50%;border:2px solid var(--gold);"></div>
      Aujourd'hui
    </div>
  </div>
</section>


    <!-- Section : Notes -->
    <section class="db-section" id="section-notes">
  <h2 class="db-section-title">Mes évaluations</h2>
  <div class="db-evals">
    <div class="db-eval-card">
      <div class="db-eval-header">
        <span class="db-eval-date">Séance 4 — 28/07/2026</span>
        <span class="db-note-cours">Langue arabe</span>
      </div>
      <div class="db-eval-body">
        <div class="db-eval-row">
          <span>Lecture</span>
          <div class="db-eval-bar"><div class="db-eval-fill" style="width:80%"></div></div>
          <span class="db-eval-score">16/20</span>
        </div>
        <div class="db-eval-row">
          <span>Compréhension</span>
          <div class="db-eval-bar"><div class="db-eval-fill" style="width:70%"></div></div>
          <span class="db-eval-score">14/20</span>
        </div>
        <div class="db-eval-row">
          <span>Expression orale</span>
          <div class="db-eval-bar"><div class="db-eval-fill" style="width:60%"></div></div>
          <span class="db-eval-score">12/20</span>
        </div>
      </div>
      <div class="db-eval-comment">
        <b>Commentaire de l'enseignant :</b> Bon travail, continuez les efforts sur l'expression orale.
      </div>
    </div>
    <div class="db-eval-empty">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>
      <span>Les prochaines évaluations apparaîtront ici</span>
    </div>
  </div>
</section>

    <!-- Section : Profil -->
    <section class="db-section" id="section-profil">
      <h2 class="db-section-title">Mon profil</h2>
      <div class="db-profil-card">
        <div class="db-profil-avatar">{{ app.user.fullName|first|upper }}</div>
        <div class="db-profil-info">
          <div class="db-profil-field">
            <label>Nom complet</label>
            <span>{{ app.user.fullName }}</span>
          </div>
          <div class="db-profil-field">
            <label>Adresse email</label>
            <span>{{ app.user.email }}</span>
          </div>
          <div class="db-profil-field">
            <label>Cours suivi</label>
            <span>{{ membership and membership.selectedCourses|length > 0 ? membership.selectedCourses|map(c => c.label)|join(', ') : '-' }}</span>
          </div>
          <div class="db-profil-field">
            <label>Statut</label>
            <span class="db-profil-badge">{{ membership ? membership.status.label : '-' }}</span>
          </div>
          {% if is_granted('ROLE_TEACHER') or is_granted('ROLE_ADMIN') %}
            <div class="db-profil-field">
              <label>Mes autres espaces</label>
              <span>
                {% if is_granted('ROLE_TEACHER') %}<a href="{{ path('app_espace_enseignant') }}">Espace enseignant</a>{% endif %}
                {% if is_granted('ROLE_ADMIN') %}<a href="{{ path('app_admin_dashboard') }}">Administration</a>{% endif %}
              </span>
            </div>
          {% endif %}
        </div>
        <button class="db-profil-edit">Modifier mon profil</button>
      </div>
    </section>

  </main>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
{{ encore_entry_script_tags('dashboard-eleve') }}
{% endblock %}
