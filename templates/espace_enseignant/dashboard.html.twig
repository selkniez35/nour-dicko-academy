{% extends 'base.html.twig' %}



{% block title %}Espace enseignant — Nour Dicko Academy{% endblock %}

{% block body %}
<div class="dashboard">

<div class="welcome-toast" id="welcome-toast">
  <div class="welcome-toast-icon">
    <svg viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>
  </div>
  <div class="welcome-toast-body">
    <div class="welcome-toast-title">Bienvenue, Enseignant 👋</div>
    <div class="welcome-toast-sub">Vous êtes connecté à votre espace enseignant</div>
  </div>
</div>

  <!-- Sidebar -->
  <aside class="db-sidebar">
    <div class="db-brand">
      <img src="{{ asset('images/logo-nda.png') }}" alt="NDA">
    </div>
    <nav class="db-nav">
      <a href="#" class="db-nav-item active" data-section="classes">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/></svg>
        Mes classes
      </a>
      <a href="#" class="db-nav-item" data-section="supports">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><path d="M14 2v6h6M16 13H8M16 17H8M10 9H8"/></svg>
        Supports
      </a>
      <a href="#" class="db-nav-item" data-section="enregistrements">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2"/></svg>
        Enregistrements
      </a>
      <a href="#" class="db-nav-item" data-section="calendrier">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="17" rx="2"/><path d="M3 9h18M8 2v4M16 2v4"/></svg>
        Calendrier
      </a>
      <a href="#" class="db-nav-item" data-section="evaluations">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>
        Évaluations
      </a>
      <a href="#" class="db-nav-item" data-section="profil">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
        Mon profil
      </a>
    </nav>
    <a href="/" class="db-logout">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4M16 17l5-5-5-5M21 12H9"/></svg>
      Déconnexion
    </a>
  </aside>

  <!-- Contenu principal -->
  <main class="db-main">

    <!-- Header -->
    <div class="db-header">
      <div>
        <h1 class="db-welcome">Bonjour, <span>Enseignant</span> 👋</h1>
        <p class="db-sub">Espace enseignant — Nour Dicko Academy</p>
      </div>
      <div class="db-avatar-wrap">
        <div class="db-avatar db-avatar-prof" onclick="toggleAvatarMenu()">E</div>
        <div class="db-avatar-menu" id="avatar-menu">
          <a href="#" onclick="showSection('profil'); toggleAvatarMenu()">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
            Mon profil
          </a>
          <a href="/" class="db-avatar-logout">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4M16 17l5-5-5-5M21 12H9"/></svg>
            Déconnexion
          </a>
        </div>
      </div>
    </div>

    <!-- Section : Mes classes -->
    <section class="db-section active" id="section-classes">
      <h2 class="db-section-title">Mes classes</h2>
      <div class="db-cours-grid">
        <div class="db-cours-card">
          <div class="db-cours-icon"><span class="glyph" lang="ar">ض</span></div>
          <div class="db-cours-info">
            <h3>Langue arabe — Classe A</h3>
            <span class="db-cours-badge">Lundi · 19h00 · 8 élèves</span>
          </div>
          <a href="#" class="db-btn-zoom">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="13" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
            Démarrer le cours
          </a>
        </div>
      </div>

      <!-- Liste des élèves -->
      <h3 class="db-subsection-title">Mes élèves</h3>
<div class="admin-table">
  <div class="admin-table-header" style="grid-template-columns:2fr 2fr 1.5fr 1.2fr;">
    <span>Nom</span>
    <span>Email</span>
    <span>Dernière séance</span>
    <span>Statut</span>
  </div>
  <div class="admin-table-row" style="grid-template-columns:2fr 2fr 1.5fr 1.2fr;">
    <span class="db-eleve-name"><div class="db-eleve-avatar">A</div>Ahmed Martin</span>
    <span>ahmed@email.com</span>
    <span>07/07/2026</span>
    <span class="db-eleve-badge db-badge-actif">Actif</span>
  </div>
  <div class="admin-table-row" style="grid-template-columns:2fr 2fr 1.5fr 1.2fr;">
    <span class="db-eleve-name"><div class="db-eleve-avatar">S</div>Sarah Dupont</span>
    <span>sarah@email.com</span>
    <span>07/07/2026</span>
    <span class="db-eleve-badge db-badge-actif">Actif</span>
  </div>
  <div class="admin-table-row" style="grid-template-columns:2fr 2fr 1.5fr 1.2fr;">
    <span class="db-eleve-name"><div class="db-eleve-avatar">M</div>Mohamed Ali</span>
    <span>mohamed@email.com</span>
    <span>30/06/2026</span>
    <span class="db-eleve-badge db-badge-absent" style="background:rgba(239,68,68,.1);color:#dc2626;font-size:11.5px;font-weight:700;padding:3px 10px;border-radius:999px;display:inline-block;">Absent</span>
  </div>
</div>
</section>

    <!-- Section : Supports -->
    <section class="db-section" id="section-supports">
      <h2 class="db-section-title">Supports de cours</h2>
      <div class="db-upload-zone">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M17 8l-5-5-5 5M12 3v12"/></svg>
        <span>Déposer un fichier ici</span>
        <small>PDF, Word, PowerPoint acceptés</small>
        <label class="db-upload-btn" style="cursor:pointer;">
  Choisir un fichier
  <input type="file" accept=".pdf,.doc,.docx,.ppt,.pptx" style="display:none;" onchange="this.parentElement.textContent = this.files[0] ? this.files[0].name : 'Choisir un fichier'">
</label>
      </div>
      <div class="db-resources">
        <div class="db-resource-item">
          <div class="db-resource-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><path d="M14 2v6h6"/></svg>
          </div>
          <div class="db-resource-info">
            <span class="db-resource-name">Support — Séance 1</span>
            <span class="db-resource-date">Ajouté le 01/07/2026 · Partagé avec Classe A</span>
          </div>
          <div class="db-resource-actions">
            <button class="db-resource-share" onclick="openModal('modal-partager-support')">Partager</button>
            <a href="#" class="db-resource-dl">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M7 10l5 5 5-5M12 15V3"/></svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Section : Enregistrements -->
    <section class="db-section" id="section-enregistrements">
      <h2 class="db-section-title">Enregistrements</h2>
      <div class="db-upload-zone">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2"/></svg>
        <span>Déposer un enregistrement</span>
        <small>MP4, MOV acceptés</small>
        <label class="db-upload-btn" style="cursor:pointer;">
  Choisir un fichier
  <input type="file" accept=".mp4,.mov,.avi" style="display:none;" onchange="this.parentElement.textContent = this.files[0] ? this.files[0].name : 'Choisir un fichier'">
</label>
      </div>
      <div class="db-resources">
        <div class="db-resource-item db-resource-video">
          <div class="db-resource-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2"/></svg>
          </div>
          <div class="db-resource-info">
            <span class="db-resource-name">Enregistrement — Séance 1</span>
            <span class="db-resource-date">Durée : 58 min · Classe A</span>
          </div>
          <div class="db-resource-actions">
            <button class="db-resource-share" onclick="openModal('modal-partager-enregistrement')">Partager</button>
            <a href="#" class="db-resource-dl">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polygon points="10 8 16 12 10 16 10 8"/></svg>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Section : Calendrier -->
   <section class="db-section" id="section-calendrier">
  <h2 class="db-section-title">Calendrier des cours 2026–2027</h2>

  <!-- Stats -->
  <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:28px;">
    <div class="db-stat-mini">
      <div class="db-stat-mini-val">148</div>
      <div class="db-stat-mini-label">Séances prévues</div>
    </div>
    <div class="db-stat-mini">
      <div class="db-stat-mini-val">10</div>
      <div class="db-stat-mini-label">Mois de cours</div>
    </div>
    <div class="db-stat-mini">
      <div class="db-stat-mini-val">19h–20h</div>
      <div class="db-stat-mini-label">Horaire habituel</div>
    </div>
  </div>

  <!-- Navigation -->
  <div style="display:flex;align-items:center;justify-content:center;gap:20px;margin-bottom:24px;">
    <button onclick="prevMonth()" style="background:var(--black);color:var(--gold);border:none;cursor:pointer;width:38px;height:38px;border-radius:50%;font-size:18px;display:flex;align-items:center;justify-content:center;">‹</button>
    <div id="nav-title" style="font-family:var(--font-display);font-size:24px;font-weight:700;min-width:220px;text-align:center;"></div>
    <button onclick="nextMonth()" style="background:var(--black);color:var(--gold);border:none;cursor:pointer;width:38px;height:38px;border-radius:50%;font-size:18px;display:flex;align-items:center;justify-content:center;">›</button>
  </div>

  <!-- Grille -->
  <div style="background:var(--white);border-radius:18px;border:1px solid var(--gold-pale);overflow:hidden;box-shadow:var(--shadow);">
    <div style="display:grid;grid-template-columns:repeat(7,1fr);background:var(--black);">
      <div class="nda-cal-dayname">Lun</div>
      <div class="nda-cal-dayname">Mar</div>
      <div class="nda-cal-dayname">Mer</div>
      <div class="nda-cal-dayname">Jeu</div>
      <div class="nda-cal-dayname">Ven</div>
      <div class="nda-cal-dayname">Sam</div>
      <div class="nda-cal-dayname">Dim</div>
    </div>
    <div id="cal-days" style="display:grid;grid-template-columns:repeat(7,1fr);"></div>
  </div>

  <!-- Légende -->
  <div style="display:flex;align-items:center;gap:24px;margin-top:18px;justify-content:center;flex-wrap:wrap;">
    <div style="display:flex;align-items:center;gap:8px;font-size:12px;opacity:.7;">
      <div style="width:12px;height:12px;border-radius:50%;background:rgba(201,146,42,.3);border:1px solid var(--gold);"></div>
      Jour de cours
    </div>
    <div style="display:flex;align-items:center;gap:8px;font-size:12px;opacity:.7;">
      <div style="width:12px;height:12px;border-radius:50%;background:#f5f5f5;border:1px solid #ddd;"></div>
      Week-end
    </div>
    <div style="display:flex;align-items:center;gap:8px;font-size:12px;opacity:.7;">
      <div style="width:12px;height:12px;border-radius:50%;border:2px solid var(--gold);"></div>
      Aujourd'hui
    </div>
  </div>

</section>

    <!-- Section : Évaluations -->
    <section class="db-section" id="section-evaluations">
      <h2 class="db-section-title">Évaluations des élèves</h2>
      <div class="db-eval-prof-grid">
        <div class="db-eval-prof-card">
          <div class="db-eval-prof-header">
            <div class="db-eleve-avatar">A</div>
            <div>
              <h4>Ahmed Martin</h4>
              <span>Langue arabe — Classe A</span>
            </div>
            <button class="db-eval-add-btn" onclick="openModal('modal-add-eval')">+ Ajouter</button>
          </div>
          <div class="db-eval-body">
            <div class="db-eval-row">
              <span>Lecture</span>
              <div class="db-eval-bar"><div class="db-eval-fill" style="width:80%"></div></div>
              <span class="db-eval-score">16/20</span>
            </div>
            <div class="db-eval-row">
              <span>Compréhension</span>
              <div class="db-eval-bar"><div class="db-eval-fill" style="width:70%"></div></div>
              <span class="db-eval-score">14/20</span>
            </div>
          </div>
          <textarea class="db-eval-comment-input" placeholder="Commentaire pour l'élève..."></textarea>
          <button class="db-eval-save">Enregistrer</button>
        </div>
      </div>
    </section>

    <!-- Section : Profil -->
    <section class="db-section" id="section-profil">
      <h2 class="db-section-title">Mon profil</h2>
      <div class="db-profil-card">
        <div class="db-profil-avatar db-avatar-prof">E</div>
        <div class="db-profil-info">
          <div class="db-profil-field">
            <label>Nom complet</label>
            <span>Prénom Nom</span>
          </div>
          <div class="db-profil-field">
            <label>Adresse email</label>
            <span>enseignant@nda.com</span>
          </div>
          <div class="db-profil-field">
            <label>Cours enseigné</label>
            <span>Langue arabe</span>
          </div>
          <div class="db-profil-field">
            <label>Classes</label>
            <span>Classe A · Classe B</span>
          </div>
        </div>
        <button class="db-profil-edit">Modifier mon profil</button>
      </div>
    </section>

<!-- ══ MODAL PARTAGER SUPPORT ══ -->
<div class="modal-overlay" id="modal-partager-support">
  <div class="modal-box" style="max-width:460px;">
    <button class="modal-close" onclick="closeModal('modal-partager-support')">×</button>
    <h3 style="font-family:var(--font-display);font-size:22px;font-weight:700;color:var(--ink);margin:0 0 6px;">Partager le support</h3>
    <p style="font-size:14px;color:var(--ink);opacity:.6;margin:0 0 24px;">Choisir les classes qui recevront ce support</p>

    <div style="display:flex;flex-direction:column;gap:10px;margin-bottom:28px;">
      <label style="display:flex;align-items:center;gap:12px;background:var(--paper);border:1.5px solid var(--gold-pale);border-radius:10px;padding:14px 16px;cursor:pointer;">
        <input type="checkbox" style="width:18px;height:18px;accent-color:var(--gold);">
        <div>
          <div style="font-size:14px;font-weight:600;color:var(--ink);">Langue arabe — Classe A</div>
          <div style="font-size:12px;color:var(--ink);opacity:.5;">8 élèves · Lundi 19h00</div>
        </div>
      </label>
      <label style="display:flex;align-items:center;gap:12px;background:var(--paper);border:1.5px solid var(--gold-pale);border-radius:10px;padding:14px 16px;cursor:pointer;">
        <input type="checkbox" style="width:18px;height:18px;accent-color:var(--gold);">
        <div>
          <div style="font-size:14px;font-weight:600;color:var(--ink);">Langue arabe — Classe B</div>
          <div style="font-size:12px;color:var(--ink);opacity:.5;">6 élèves · Mardi 19h00</div>
        </div>
      </label>
      <label style="display:flex;align-items:center;gap:12px;background:var(--paper);border:1.5px solid var(--gold-pale);border-radius:10px;padding:14px 16px;cursor:pointer;">
        <input type="checkbox" style="width:18px;height:18px;accent-color:var(--gold);">
        <div>
          <div style="font-size:14px;font-weight:600;color:var(--ink);">Éducation islamique</div>
          <div style="font-size:12px;color:var(--ink);opacity:.5;">12 élèves · Mercredi 19h00</div>
        </div>
      </label>
    </div>

    <div style="display:flex;gap:12px;justify-content:flex-end;">
      <button onclick="closeModal('modal-partager-support')" style="padding:12px 24px;border-radius:999px;font-size:14px;font-weight:600;border:1.5px solid var(--gold-pale);background:transparent;color:var(--ink);cursor:pointer;">
        Annuler
      </button>
      <button style="padding:12px 28px;border-radius:999px;font-size:14px;font-weight:600;border:none;background:var(--gold);color:#fff;cursor:pointer;">
        Partager
      </button>
    </div>
  </div>
</div>

<!-- ══ MODAL PARTAGER ENREGISTREMENT ══ -->
<div class="modal-overlay" id="modal-partager-enregistrement">
  <div class="modal-box" style="max-width:460px;">
    <button class="modal-close" onclick="closeModal('modal-partager-enregistrement')">×</button>
    <h3 style="font-family:var(--font-display);font-size:22px;font-weight:700;color:var(--ink);margin:0 0 6px;">Partager l'enregistrement</h3>
    <p style="font-size:14px;color:var(--ink);opacity:.6;margin:0 0 24px;">Choisir les classes qui recevront cet enregistrement</p>

    <div style="display:flex;flex-direction:column;gap:10px;margin-bottom:28px;">
      <label style="display:flex;align-items:center;gap:12px;background:var(--paper);border:1.5px solid var(--gold-pale);border-radius:10px;padding:14px 16px;cursor:pointer;">
        <input type="checkbox" style="width:18px;height:18px;accent-color:var(--gold);">
        <div>
          <div style="font-size:14px;font-weight:600;color:var(--ink);">Langue arabe — Classe A</div>
          <div style="font-size:12px;color:var(--ink);opacity:.5;">8 élèves · Lundi 19h00</div>
        </div>
      </label>
      <label style="display:flex;align-items:center;gap:12px;background:var(--paper);border:1.5px solid var(--gold-pale);border-radius:10px;padding:14px 16px;cursor:pointer;">
        <input type="checkbox" style="width:18px;height:18px;accent-color:var(--gold);">
        <div>
          <div style="font-size:14px;font-weight:600;color:var(--ink);">Langue arabe — Classe B</div>
          <div style="font-size:12px;color:var(--ink);opacity:.5;">6 élèves · Mardi 19h00</div>
        </div>
      </label>
      <label style="display:flex;align-items:center;gap:12px;background:var(--paper);border:1.5px solid var(--gold-pale);border-radius:10px;padding:14px 16px;cursor:pointer;">
        <input type="checkbox" style="width:18px;height:18px;accent-color:var(--gold);">
        <div>
          <div style="font-size:14px;font-weight:600;color:var(--ink);">Éducation islamique</div>
          <div style="font-size:12px;color:var(--ink);opacity:.5;">12 élèves · Mercredi 19h00</div>
        </div>
      </label>
    </div>

    <div style="display:flex;gap:12px;justify-content:flex-end;">
      <button onclick="closeModal('modal-partager-enregistrement')" style="padding:12px 24px;border-radius:999px;font-size:14px;font-weight:600;border:1.5px solid var(--gold-pale);background:transparent;color:var(--ink);cursor:pointer;">
        Annuler
      </button>
      <button style="padding:12px 28px;border-radius:999px;font-size:14px;font-weight:600;border:none;background:var(--gold);color:#fff;cursor:pointer;">
        Partager
      </button>
    </div>
  </div>
</div>

<!-- ══ MODAL AJOUTER ÉVALUATION ══ -->
<div class="modal-overlay" id="modal-add-eval">
  <div class="modal-box" style="max-width:560px;max-height:90vh;overflow-y:auto;">
    <button class="modal-close" onclick="closeModal('modal-add-eval')">×</button>
    <h3 style="font-family:var(--font-display);font-size:24px;font-weight:700;color:var(--ink);margin:0 0 6px;">Ajouter une évaluation</h3>
    <p style="font-size:14px;color:var(--ink);opacity:.6;margin:0 0 24px;">Saisir les notes et commentaire pour un élève</p>

    <!-- Élève + séance -->
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:20px;">
      <div>
        <label style="font-size:13px;font-weight:600;color:var(--ink);display:block;margin-bottom:6px;">Élève <span style="color:var(--gold);">*</span></label>
        <select style="width:100%;font-family:var(--font-body);font-size:14px;background:var(--paper);border:1.5px solid var(--gold-pale);border-radius:8px;padding:11px 14px;box-sizing:border-box;">
          <option value="" disabled selected>Choisir...</option>
          <option>Ahmed Martin</option>
          <option>Sarah Dupont</option>
          <option>Mohamed Ali</option>
        </select>
      </div>
      <div>
        <label style="font-size:13px;font-weight:600;color:var(--ink);display:block;margin-bottom:6px;">Séance <span style="color:var(--gold);">*</span></label>
        <input type="text" placeholder="Ex : Séance 4 — 28/07/2026" style="width:100%;font-family:var(--font-body);font-size:14px;background:var(--paper);border:1.5px solid var(--gold-pale);border-radius:8px;padding:11px 14px;box-sizing:border-box;">
      </div>
    </div>

    <!-- Notes -->
    <div style="font-size:11px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(--gold-deep);margin-bottom:14px;">Notes /20</div>
    <div style="display:flex;flex-direction:column;gap:14px;margin-bottom:20px;">
      <div style="display:flex;align-items:center;gap:14px;">
        <label style="font-size:13.5px;color:var(--ink);width:140px;flex-shrink:0;">Lecture</label>
        <input type="range" min="0" max="20" value="14" oninput="this.nextElementSibling.textContent=this.value+'/20'" style="flex-grow:1;accent-color:var(--gold);">
        <span style="font-size:14px;font-weight:700;color:var(--gold-deep);width:44px;text-align:right;">14/20</span>
      </div>
      <div style="display:flex;align-items:center;gap:14px;">
        <label style="font-size:13.5px;color:var(--ink);width:140px;flex-shrink:0;">Compréhension</label>
        <input type="range" min="0" max="20" value="12" oninput="this.nextElementSibling.textContent=this.value+'/20'" style="flex-grow:1;accent-color:var(--gold);">
        <span style="font-size:14px;font-weight:700;color:var(--gold-deep);width:44px;text-align:right;">12/20</span>
      </div>
      <div style="display:flex;align-items:center;gap:14px;">
        <label style="font-size:13.5px;color:var(--ink);width:140px;flex-shrink:0;">Expression orale</label>
        <input type="range" min="0" max="20" value="10" oninput="this.nextElementSibling.textContent=this.value+'/20'" style="flex-grow:1;accent-color:var(--gold);">
        <span style="font-size:14px;font-weight:700;color:var(--gold-deep);width:44px;text-align:right;">10/20</span>
      </div>
    </div>

    <!-- Commentaire -->
    <div style="margin-bottom:28px;">
      <label style="font-size:13px;font-weight:600;color:var(--ink);display:block;margin-bottom:6px;">Commentaire pour l'élève</label>
      <textarea rows="4" placeholder="Commentaire sur la progression, les points à améliorer..." style="width:100%;font-family:var(--font-body);font-size:14px;background:var(--paper);border:1.5px solid var(--gold-pale);border-radius:8px;padding:11px 14px;box-sizing:border-box;resize:vertical;"></textarea>
    </div>

    <!-- Boutons -->
    <div style="display:flex;gap:12px;justify-content:flex-end;">
      <button onclick="closeModal('modal-add-eval')" style="padding:12px 24px;border-radius:999px;font-size:14px;font-weight:600;border:1.5px solid var(--gold-pale);background:transparent;color:var(--ink);cursor:pointer;">
        Annuler
      </button>
      <button style="padding:12px 28px;border-radius:999px;font-size:14px;font-weight:600;border:none;background:var(--gold);color:#fff;cursor:pointer;">
        Enregistrer
      </button>
    </div>
  </div>
</div>

  </main>
</div>
{% endblock %}

