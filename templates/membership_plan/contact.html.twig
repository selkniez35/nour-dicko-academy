{% extends 'base.html.twig' %}

{% block title %}Contact & Inscription — Nour Dicko Academy{% endblock %}

{% block body %}
    <section id="inscription">
      <div class="wrap">
        <div class="sec-head reveal">
          <span class="sec-tag">Inscription</span>
          <h2 class="sec-title">Inscrivez-vous dès maintenant !</h2>
          <p class="sec-sub">Les places sont limitées — remplissez le formulaire et nous vous recontactons rapidement.</p>
        </div>

        <div class="enroll-grid">
          <div class="qr-card reveal">
            <div class="qr" aria-hidden="true">
