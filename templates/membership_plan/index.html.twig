{% extends 'base.html.twig' %}

{% block title %}Nour Dicko Academy — Institut d'enseignement islamique en ligne{% endblock %}

{% block body %}
<!-- ══ NAVIGATION ══ -->
<header class="topbar">
  <div class="topbar-in">
    <a href="#" class="brand" aria-label="Nour Dicko Academy — accueil">
      <svg class="brand-mono" viewBox="0 0 48 48" aria-hidden="true">
        <path d="M24 4a20 20 0 100 40 22 22 0 01-6-40 20 20 0 016 0z" fill="none" stroke="#C9922A" stroke-width="1.6"/>
        <text x="17" y="33" font-family="Cormorant Garamond,serif" font-size="26" font-weight="700" fill="#181510">N</text>
        <polygon points="36,8 37.3,11 40.3,12.3 37.3,13.6 36,16.6 34.7,13.6 31.7,12.3 34.7,11" fill="#C9922A"/>
      </svg>
      <span class="brand-name">NOUR <b>DICKO</b></span>
    </a>
    <nav aria-label="Navigation principale">
      <ul class="nav-links">
        <li><a href="#cours">Nos cours</a></li>
        <li><a href="#tarifs">Tarifs</a></li>
        <li><a href="#apropos">À propos</a></li>
        <li><a href="#inscription">Contact</a></li>
      </ul>
    </nav>
    <a class="btn btn-black" href="#inscription">S'inscrire</a>
  </div>
</header>

<!-- ══ HERO ══ -->
<div class="hero">
  <div class="pattern-corner pattern-tl" aria-hidden="true">
    <svg viewBox="0 0 100 100"><g fill="none" stroke="#C9922A" stroke-width=".7">
      <path d="M0 50 L25 25 L50 50 L25 75 Z M25 25 L50 0 L75 25 L50 50 Z M50 50 L75 25 L100 50 L75 75 Z M25 75 L50 50 L75 75 L50 100 Z"/>
      <circle cx="25" cy="50" r="6"/><circle cx="50" cy="25" r="6"/><circle cx="75" cy="50" r="6"/><circle cx="50" cy="75" r="6"/>
    </g></svg>
  </div>
  <div class="pattern-corner pattern-tr" aria-hidden="true">
    <svg viewBox="0 0 100 100"><g fill="none" stroke="#C9922A" stroke-width=".7">
      <path d="M0 50 L25 25 L50 50 L25 75 Z M25 25 L50 0 L75 25 L50 50 Z M50 50 L75 25 L100 50 L75 75 Z M25 75 L50 50 L75 75 L50 100 Z"/>
      <circle cx="25" cy="50" r="6"/><circle cx="50" cy="25" r="6"/><circle cx="75" cy="50" r="6"/><circle cx="50" cy="75" r="6"/>
    </g></svg>
  </div>

  <div class="hero-arch">
    <svg class="hero-logo" viewBox="0 0 120 96" aria-hidden="true">
      <path d="M52 10a38 38 0 100 76 42 42 0 01-10-76 38 38 0 0110 0z" fill="none" stroke="#C9922A" stroke-width="2"/>
      <text x="34" y="66" font-family="Cormorant Garamond,serif" font-size="52" font-weight="700" fill="#181510">N</text>
      <text x="62" y="66" font-family="Cormorant Garamond,serif" font-size="44" font-weight="600" fill="#181510">DA</text>
      <polygon points="88,12 90,17 95,19 90,21 88,26 86,21 81,19 86,17" fill="#C9922A"/>
    </svg>
    <div class="hero-brand">NOUR <b>DICKO</b></div>
    <div class="hero-academy">Academy</div>
    <div class="hero-ar" lang="ar" dir="rtl">نور العلم للجميع</div>

    <div class="badge">Réservé exclusivement aux adultes</div>
    <h1>Institut d'enseignement<br>islamique en ligne</h1>

    <div class="hero-motto" aria-label="Apprendre, comprendre, progresser">
      <span>Apprendre</span><span class="dot" aria-hidden="true"></span>
      <span>Comprendre</span><span class="dot" aria-hidden="true"></span>
      <span>Progresser</span>
    </div>

    <div class="hero-pills">
      <span class="pill">
        <svg viewBox="0 0 24 24" fill="none" stroke="#C9922A" stroke-width="2" aria-hidden="true"><rect x="2" y="4" width="20" height="13" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
        Cours 100% en ligne
      </span>
      <span class="pill">
        <svg viewBox="0 0 24 24" fill="none" stroke="#C9922A" stroke-width="2" aria-hidden="true"><rect x="3" y="4" width="18" height="17" rx="2"/><path d="M3 9h18M8 2v4M16 2v4"/></svg>
        1 cours par semaine
      </span>
      <span class="pill">
        <svg viewBox="0 0 24 24" fill="none" stroke="#C9922A" stroke-width="2" aria-hidden="true"><circle cx="9" cy="8" r="3.5"/><path d="M2.5 20c.8-3.6 3.4-5.5 6.5-5.5s5.7 1.9 6.5 5.5M16 4.6a3.5 3.5 0 010 6.8M21.5 20c-.5-2.4-1.8-4-3.7-4.9"/></svg>
        Places limitées
      </span>
    </div>

    <div class="hero-cta">
      <a class="btn btn-gold" href="#inscription">Je m'inscris maintenant</a>
      <a class="btn btn-line" href="#cours">Découvrir les cours</a>
    </div>
  </div>
  <div class="hero-base"></div>
</div>

<!-- ══ NOS COURS ══ -->
<section id="cours">
  <div class="wrap">
    <div class="sec-head reveal">
      <span class="sec-tag">Nos cours</span>
      <h2 class="sec-title">Trois parcours, un même objectif</h2>
      <p class="sec-sub">Chaque cours a lieu une fois par semaine, en direct et en ligne, à horaire fixe en soirée.</p>
    </div>

    <div class="courses">
      <!-- Langue arabe -->
      <article class="course reveal">
        <div class="course-icon ic-black"><span class="glyph" lang="ar">ض</span></div>
        <h3>Langue arabe</h3>
        <div class="course-level">Niveau avancé requis</div>
        <div class="course-feats">
          <span class="feat"><svg viewBox="0 0 24 24" fill="none" stroke="#C9922A" stroke-width="2" aria-hidden="true"><path d="M4 19V5a2 2 0 012-2h13v16H6a2 2 0 000 4h13"/></svg>Lire</span>
          <span class="feat"><svg viewBox="0 0 24 24" fill="none" stroke="#C9922A" stroke-width="2" aria-hidden="true"><path d="M21 11a8 8 0 01-11.9 7L3 20l2-6.1A8 8 0 1121 11z"/><path d="M8.5 11h.01M12 11h.01M15.5 11h.01"/></svg>Comprendre</span>
          <span class="feat"><svg viewBox="0 0 24 24" fill="none" stroke="#C9922A" stroke-width="2" aria-hidden="true"><circle cx="9" cy="7" r="3.5"/><path d="M3.5 20c.7-3.4 2.8-5 5.5-5s4.8 1.6 5.5 5M16 6l4 4m0-4l-4 4"/></svg>Parler</span>
        </div>
        <p>Approfondissez votre maîtrise de la langue arabe : lecture, compréhension et expression orale.</p>
        <div class="course-when">
          <svg viewBox="0 0 24 24" fill="none" stroke="#C9922A" stroke-width="2" aria-hidden="true"><rect x="3" y="4" width="18" height="17" rx="2"/><path d="M3 9h18M8 2v4M16 2v4"/></svg>
          <div>
            <div class="when-day">Lundi ou mardi</div>
            <div class="when-note">En fonction de la classe</div>
            <div class="when-hour">19h00 – 20h00</div>
          </div>
        </div>
        <div class="course-places">2 classes · 20 élèves max</div>
      </article>

      <!-- Éducation islamique -->
      <article class="course reveal">
        <div class="course-icon ic-gold">
          <svg viewBox="0 0 24 24" fill="none" stroke="#0C0C0C" stroke-width="1.8" aria-hidden="true">
            <path d="M12 2c0 3-3.5 4-3.5 7a3.5 3.5 0 007 0C15.5 6 12 5 12 2z"/>
            <path d="M4 21v-7h16v7M4 21h16M9 21v-4a3 3 0 016 0v4"/>
          </svg>
        </div>
        <h3>Éducation islamique</h3>
        <div class="course-level">Ouvert à tous</div>
        <div class="course-feats">
          <span class="feat"><svg viewBox="0 0 24 24" fill="none" stroke="#C9922A" stroke-width="2" aria-hidden="true"><path d="M12 3c2.5 3.8 6 6.3 6 10a6 6 0 11-12 0c0-3.7 3.5-6.2 6-10z"/></svg>Purification</span>
          <span class="feat"><svg viewBox="0 0 24 24" fill="none" stroke="#C9922A" stroke-width="2" aria-hidden="true"><circle cx="12" cy="5" r="2.5"/><path d="M12 8v5l-4 6m4-6l4 6"/></svg>Prière</span>
          <span class="feat"><svg viewBox="0 0 24 24" fill="none" stroke="#C9922A" stroke-width="2" aria-hidden="true"><path d="M12 21V8M12 8c0-3 2-5 6-5v13c-4 0-6 1-6 5zm0 0c0-3-2-5-6-5v13c4 0 6 1 6 5z"/></svg>Invocations</span>
        </div>
        <p>Initiation à la purification, à la prière et apprentissage des invocations quotidiennes.</p>
        <div class="course-when">
          <svg viewBox="0 0 24 24" fill="none" stroke="#C9922A" stroke-width="2" aria-hidden="true"><rect x="3" y="4" width="18" height="17" rx="2"/><path d="M3 9h18M8 2v4M16 2v4"/></svg>
          <div>
            <div class="when-day">Mercredi</div>
            <div class="when-hour">19h00 – 20h00</div>
          </div>
        </div>
        <div class="course-places">Tous niveaux · ouvert à tous</div>
      </article>

      <!-- Lecture du Coran -->
      <article class="course reveal">
        <div class="course-icon ic-black">
          <svg viewBox="0 0 24 24" fill="none" stroke="#C9922A" stroke-width="1.8" aria-hidden="true">
            <path d="M12 20V7M12 7c0-2.8 2-4.5 7-4.5v13c-5 0-7 1.2-7 4.5zm0 0c0-2.8-2-4.5-7-4.5v13c5 0 7 1.2 7 4.5z"/>
            <path d="M3 21h18" stroke-linecap="round"/>
          </svg>
        </div>
        <h3>Apprendre à lire le Coran</h3>
        <div class="course-level">Débutant</div>
        <div class="course-feats">
          <span class="feat"><svg viewBox="0 0 24 24" fill="none" stroke="#C9922A" stroke-width="2" aria-hidden="true"><path d="M4 20h16M6 16l6-12 6 12"/><path d="M8.5 12h7"/></svg>Alphabet</span>
          <span class="feat"><svg viewBox="0 0 24 24" fill="none" stroke="#C9922A" stroke-width="2" aria-hidden="true"><path d="M4 19V5a2 2 0 012-2h13v16H6a2 2 0 000 4h13"/></svg>Lecture</span>
          <span class="feat"><svg viewBox="0 0 24 24" fill="none" stroke="#C9922A" stroke-width="2" aria-hidden="true"><path d="M5 12l4 4L19 6"/></svg>Progression</span>
        </div>
        <p>Apprenez à lire le Coran pas à pas, depuis les bases, dans un cadre bienveillant.</p>
        <div class="course-when">
          <svg viewBox="0 0 24 24" fill="none" stroke="#C9922A" stroke-width="2" aria-hidden="true"><rect x="3" y="4" width="18" height="17" rx="2"/><path d="M3 9h18M8 2v4M16 2v4"/></svg>
          <div>
            <div class="when-day">Jeudi</div>
            <div class="when-hour">19h00 – 20h00</div>
          </div>
        </div>
        <div class="course-places">1 classe · 15 élèves max</div>
      </article>
    </div>
  </div>
</section>

<!-- ══ BANDEAU INFO ══ -->
<div class="infoband reveal">
  <div class="infoband-in">
    <div class="info-item">
      <div class="info-ic">
        <svg viewBox="0 0 24 24" fill="none" stroke="#C9922A" stroke-width="2" aria-hidden="true"><rect x="2" y="4" width="20" height="13" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
      </div>
      <div>
        <h4>Cours 100% en ligne</h4>
        <p>Depuis chez vous, où que vous soyez.</p>
      </div>
    </div>
    <div class="info-item">
      <div class="info-ic">
        <svg viewBox="0 0 24 24" fill="none" stroke="#C9922A" stroke-width="2" aria-hidden="true"><circle cx="12" cy="8" r="3.5"/><path d="M5 20c.9-3.9 3.6-6 7-6s6.1 2.1 7 6"/></svg>
      </div>
      <div>
        <h4>1 cours par semaine</h4>
        <p>Engagement annuel — une progression régulière.</p>
      </div>
    </div>
  </div>
</div>

<!-- ══ TARIFS ══ -->
<section id="tarifs">
  <div class="wrap">
    <div class="sec-head reveal">
      <span class="sec-tag">Nos tarifs</span>
      <h2 class="sec-title">Une inscription pour toute l'année</h2>
      <p class="sec-sub">Des tarifs simples et transparents, avec des facilités de paiement sans frais.</p>
    </div>

    <div class="prices">
      <article class="price reveal">
        <div class="price-cap">1 cours au choix</div>
        <div class="price-body">
          <div class="price-val">250 € <small>/an</small></div>
          <div class="price-choice">Au choix :</div>
          <ul>
            <li>Langue arabe (niveau avancé)</li>
            <li>Apprendre à lire le Coran (débutant)</li>
          </ul>
          <a class="btn btn-black" href="#inscription">Choisir ce cours</a>
        </div>
      </article>

      <article class="price reveal">
        <div class="price-cap">1 cours au choix</div>
        <div class="price-body">
          <div class="price-val">200 € <small>/an</small></div>
          <div class="price-choice">Au choix :</div>
          <ul>
            <li>Éducation islamique (ouvert à tous)</li>
          </ul>
          <a class="btn btn-black" href="#inscription">Choisir ce cours</a>
        </div>
      </article>

      <article class="price price-featured reveal">
        <div class="price-cap">✦ Pack 2 cours au choix</div>
        <div class="price-body">
          <div class="price-val">350 € <small>/an</small></div>
          <div class="price-old">450 €</div>
          <div class="price-choice">Au choix :</div>
          <ul>
            <li>Langue arabe (avancé) + Éducation islamique</li>
          </ul>
          <div class="pack-or">ou</div>
          <ul>
            <li>Apprendre à lire le Coran (débutant) + Éducation islamique</li>
          </ul>
          <a class="btn btn-gold" href="#inscription">Choisir le pack</a>
        </div>
      </article>
    </div>

    <div class="pay-ease reveal">
      <div>
        <h3>Facilité de paiement</h3>
        <p>Payez en plusieurs fois, sans frais — simple, flexible et adapté à votre situation.</p>
      </div>
      <div class="pay-x" aria-label="Paiement en 2, 4 ou 10 fois">
        <div class="px"><b>2x</b><span>2 FOIS</span></div>
        <div class="px"><b>4x</b><span>4 FOIS</span></div>
        <div class="px"><b>10x</b><span>10 FOIS</span></div>
      </div>
    </div>
  </div>
</section>

<!-- ══ À PROPOS ══ -->
<section id="apropos" class="about">
  <div class="wrap">
    <div class="sec-head reveal">
      <span class="sec-tag">À propos</span>
      <h2 class="sec-title" style="color:var(--cream)">Un enseignement de confiance</h2>
    </div>
    <blockquote class="about-quote reveal">
      Transmettre la connaissance du Coran et de la langue arabe est une mission que je porte au cœur. Nour Dicko Academy est née de la conviction que chaque adulte mérite un accès à un enseignement islamique de qualité, structuré et bienveillant.
    </blockquote>
    <div class="about-sig reveal">
      <b>Imam Dicko</b>
      <span>Fondateur de Nour Dicko Academy</span>
    </div>
    <div class="about-vals reveal">
      <span class="pill">Apprendre</span>
      <span class="pill">Comprendre</span>
      <span class="pill">Progresser</span>
    </div>
  </div>
</section>

<!-- ══ INSCRIPTION ══ -->
<section id="inscription">
  <div class="wrap">
    <div class="sec-head reveal">
      <span class="sec-tag">Inscription</span>
      <h2 class="sec-title">Inscrivez-vous dès maintenant !</h2>
      <p class="sec-sub">Les places sont limitées — remplissez le formulaire et nous vous recontactons rapidement.</p>
    </div>

    <div class="enroll-grid">
      <div class="qr-card reveal">
        <div class="qr" aria-hidden="true">
