{% extends 'base.html.twig' %}

{% block title %}Choisir une formule{% endblock %}

{% block body %}

    <section class="hero">

        <div class="container">

        <span class="hero-badge">
            Cours en ligne • Inscriptions ouvertes
        </span>

            <h1 class="hero-title">
                Rejoignez les cours en ligne du
                <span>Sheikh Dicko</span>
            </h1>

            <p class="hero-description">

                Choisissez la formule qui correspond à votre niveau et à votre disponibilité.
                Les cours sont dispensés en ligne dans un cadre structuré, simple et accessible.
                Le paiement peut être effectué en une fois ou en plusieurs fois.

            </p>

        </div>

    </section>

    <section class="pricing">

        <div class="container">

            <div class="row justify-content-center g-4">

                {% for plan in plans %}

                    <div class="col-lg-4 col-md-6 d-flex">

                        <div class="pricing-card w-100">

                            <div class="pricing-header">

                            <span class="pricing-category">
                                Formation
                            </span>

                                <h2>

                                    {{ plan.label }}

                                </h2>

                            </div>

                            <div class="pricing-price">

                                {{ plan.price }}

                                <span>€</span>

                            </div>

                            <div class="pricing-period">

                                Paiement flexible (une fois ou en plusieurs fois)

                            </div>

                            <hr>

                            <ul class="pricing-features">

                                <li>
                                    ✔ Cours en ligne avec le Sheikh Dicko
                                </li>

                                <li>
                                    ✔ Accès aux sessions pédagogiques structurées
                                </li>

                                <li>
                                    ✔ Suivi et accompagnement progressif
                                </li>

                                <li>
                                    ✔ Contenus accessibles à tout moment
                                </li>

                                <li>
                                    ✔ Paiement sécurisé via Stripe
                                </li>

                            </ul>

                            <div class="mt-auto">

                                <a
                                    href="{{ path('app_pay', {id: plan.id}) }}"
                                    class="btn btn-gold w-100">

                                    Choisir cette formule

                                </a>

                            </div>

                        </div>

                    </div>

                {% endfor %}

            </div>

        </div>

    </section>

    <section class="why">

        <div class="container">

            <div class="row text-center">

                <div class="col-md-4">

                    <div class="feature-box">

                        <div class="feature-icon">
                            🎓
                        </div>

                        <h3>
                            Formation
                        </h3>

                        <p>
                            Un apprentissage structuré et progressif adapté à tous les niveaux.
                        </p>

                    </div>

                </div>

                <div class="col-md-4">

                    <div class="feature-box">

                        <div class="feature-icon">
                            💻
                        </div>

                        <h3>
                            En ligne
                        </h3>

                        <p>
                            Accédez aux cours où que vous soyez, sans contrainte de déplacement.
                        </p>

                    </div>

                </div>

                <div class="col-md-4">

                    <div class="feature-box">

                        <div class="feature-icon">
                            🧭
                        </div>

                        <h3>
                            Accompagnement
                        </h3>

                        <p>
                            Un suivi sérieux pour progresser étape par étape avec régularité.
                        </p>

                    </div>

                </div>

            </div>

        </div>

    </section>

{% endblock %}
