<header class="topbar">
  <div class="topbar-in">
    <a href="{{ path('app_membership-plan_index') }}" class="topbar-logo" aria-label="Nour Dicko Academy — accueil">
      <img src="{{ asset('images/logo-nda.png') }}" alt="Nour Dicko Academy">
    </a>
    <nav aria-label="Navigation principale">
      <ul class="topbar-menu">
        <li><a href="{{ path('app_membership-plan_index') }}">Accueil</a></li>
        <li><a href="{{ path('app_about') }}">À propos</a></li>
        <li><a href="{{ path('app_news') }}">Actualités</a></li>
        <li><a href="{{ path('app_courses') }}">Cours</a></li>
        <li><a href="{{ path('app_prices') }}">Tarifs</a></li>
        <li><a href="{{ path('app_contact') }}">Contact</a></li>
        {% if is_granted('ROLE_ADMIN') %}
          <li><a href="{{ path('app_admin_dashboard') }}">Admin</a></li>
        {% endif %}
      </ul>
    </nav>
    <div class="topbar-btns">

        {% if not app.user %}
          <a class="topbar-login" href="#" onclick="openModal('modal-connexion'); return false;">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M15 3h4a2 2 0 012 2v14a2 2 0 01-2 2h-4M10 17l5-5-5-5M15 12H3"/></svg>
            Connexion
          </a>
            <a class="topbar-cta" href="{{ path('app_registration') }}">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="8" r="3.5"/><path d="M5 20c1-3.8 3.8-5.5 7-5.5s6 1.7 7 5.5"/></svg>
                S'inscrire
            </a>
        {% elseif is_granted('ROLE_ADMIN') %}
            <a class="topbar-login" href="{{ path('app_logout') }}">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4M16 17l5-5-5-5M21 12H9"/></svg>
                Déconnexion
            </a>
            Salam {{ app.user.fullName }}
        {% else %}
            {% set spaceRoute = is_granted('ROLE_TEACHER') ? 'app_espace_enseignant' : 'app_espace_eleve' %}
            {% set avatarClass = is_granted('ROLE_TEACHER') ? 'db-avatar db-avatar-prof' : 'db-avatar' %}
            <div class="db-avatar-wrap topbar-avatar-wrap">
                <div class="{{ avatarClass }}" onclick="toggleHeaderAvatarMenu()">{{ app.user.fullName|first|upper }}</div>
                <div class="db-avatar-menu" id="header-avatar-menu">
                    <div class="topbar-avatar-greeting">Salam {{ app.user.fullName }}</div>
                    <a href="{{ path(spaceRoute) }}">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
                        Mon espace
                    </a>
                    <a href="{{ path('app_logout') }}" class="db-avatar-logout">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4M16 17l5-5-5-5M21 12H9"/></svg>
                        Déconnexion
                    </a>
                </div>
            </div>
        {% endif %}

    </div>
  </div>
</header>

{{ include('partials/_login_modal.html.twig') }}
