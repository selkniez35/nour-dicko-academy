{% extends 'base.html.twig' %}

{% block title %}Paiement sécurisé{% endblock %}

{% block body %}

    <section class="checkout">

        <div class="container">

            <div class="checkout-wrapper">

                <div class="checkout-left">

                    <div class="checkout-card">

                        <div class="checkout-header">

                        <span class="secure-badge">
                            🔒 Paiement sécurisé Stripe
                        </span>

                            <h1>
                                Finaliser votre inscription
                            </h1>

                            <p>
                                Votre paiement est crypté et sécurisé.
                            </p>

                        </div>

                        <div class="checkout-body">

                            <div class="info-row">

                                <span>Adhérent</span>

                                <strong>
                                    {{ membership.userProfile.fullName() }}
                                </strong>

                            </div>

                            <div class="info-row">

                                <span>Formule</span>

                                <strong>
                                    {{ membership.plan.label ?? 'Licence' }}
                                </strong>

                            </div>

                            <div class="info-row price">

                                <span>Montant</span>

                                <strong>
                                    {{ membership.price ?? 100 }} €
                                </strong>

                            </div>

                        </div>

                        <form method="POST" class="checkout-form">

                            <button type="submit" class="btn-pay">

                                Payer maintenant

                            </button>

                        </form>

                        <div class="checkout-footer">

                            <small>
                                🔐 Paiement sécurisé via Stripe • Données cryptées
                            </small>

                        </div>

                    </div>

                </div>

                <div class="checkout-right">

                    <div class="summary-card">

                        <h3>Résumé</h3>

                        <ul>

                            <li>✔ Accès immédiat</li>

                            <li>✔ Licence officielle</li>

                            <li>✔ Assurance incluse</li>

                            <li>✔ Support prioritaire</li>

                        </ul>

                        <div class="highlight-box">

                            <p>
                                “Une inscription rapide et sécurisée pour rejoindre
                                la meilleure académie.”
                            </p>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </section>

{% endblock %}
